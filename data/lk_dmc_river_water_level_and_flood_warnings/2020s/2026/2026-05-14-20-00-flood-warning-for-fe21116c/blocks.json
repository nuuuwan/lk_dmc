    "text": "\u0b8e\u0ba9\u0ba8\u0bb5, \u0b85\u0ba8\u0bcd\u0ba4\u0baa\u0bcd \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0bb5\u0b9a\u0bbf\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0baa\u0baa\u0bbe\u0ba4\u0bc1\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bc1\u0bae\u0bcd, \u0b85\u0ba8\u0bcd\u0ba4\u0baa\u0bcd \u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0b95\u0bb3\u0bcd \u0bb5\u0bc8\u0bbf\u0baf\u0bbe\u0b95\u0baa\u0bcd \u0baa\u0baf\u0ba3\u0bae\u0bcd \u0baa\u0b9a\u0baf\u0bcd\u0baf\u0bc1\u0bae\u0bcd \u0bb5\u0bbe\u0b95\u0ba9 \u0b93\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bb3\u0bc1\u0bae\u0bcd \u0bae\u0bbf\u0b95\u0bc1\u0ba8\u0bcd\u0ba4 \u0b85\u0bb5\u0ba4\u0bbe\u0ba9\u0ba4\u0bcd\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd \u0baa\u0b9a\u0baf\u0bb2\u0bcd\u0baa\u0b9f\u0bc1\u0bae\u0bbe\u0bb1\u0bc1 \u0ba8\u0b95\u0b9f\u0bcd\u0b9f\u0bc1\u0b95\u0bcd\u0baa\u0b95\u0bbe\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0b95\u0bbf\u0bb1\u0bbe\u0bb0\u0bcd\u0b95\u0bb3\u0bcd.",
