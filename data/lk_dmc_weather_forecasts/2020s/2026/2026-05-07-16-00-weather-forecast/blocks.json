    "bbox": [
      217.13,
      511.03,
      419.16,
      523.99
    ],
    "text": "Issued at 04.00 p.m. on 07 May 2026.",
    "fonts": [
      "Calibri-Bold"
    ],
    "sizes": [
      12.0,
      12.960000038146973
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      526.87,
      554.52,
      582.31
    ],
    "text": "Due to the low-level atmospheric disturbance in the vicinity of Sri Lanka, the prevailing showery condition over the island is expected to continue during the next few days",
    "fonts": [
      "Calibri-Bold"
    ],
    "sizes": [
      9.0,
      12.0,
      12.960000038146973
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      585.85,
      456.5,
      606.19
    ],
    "text": "Showers or thundershowers will occur at most places of the island after 1.00 pm.",
    "fonts": [
      "Calibri",
      "Calibri-Bold",
      "Iskoola Pota"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      609.58,
      457.7,
      628.63
    ],
    "text": "Showers are likely in the Eastern and Northern provinces during the morning too.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      3.9600000381469727,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      637.03,
      552.53,
      669.43
    ],
    "text": "Heavy falls above 100 mm are likely at some places in Western, Sabaragamuwa, Central, Uva, North-western provinces and in Galle and Matara districts.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      0.9599999785423279,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      672.85,
      554.69,
      710.14
    ],
    "text": "Misty conditions can be expected at some places in Central, Sabaragamuwa and Uva provinces during the early hours of the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      5.039999961853027,
      9.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      714.04,
      554.47,
      950.16
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damages caused by temporary localized strong winds and lightning during thundershowers.",
    "fonts": [
