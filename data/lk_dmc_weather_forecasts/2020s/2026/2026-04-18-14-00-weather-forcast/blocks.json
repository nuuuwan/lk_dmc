    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      511.15,
      534.05,
      594.19
    ],
    "text": "Atmospheric conditions for evening thundershowers are expected to become favorable in most parts of the island from the 20th of April onwards. Showers or thundershowers will occur at several places in Western, Central, Sabaragamuwa, Uva, North-western and Southern provinces after 1.00 pm.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      0.9599999785423279,
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      597.1,
      378.74,
      615.31
    ],
    "text": "Mainly dry weather will prevail over the other parts of the island.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      3.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      618.46,
      534.03,
      654.55
    ],
    "text": "Misty conditions can be expected at some places in Western, Central, Sabaragamuwa and Uva provinces and in Galle and Matara districts during the early hours of the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      3.9600000381469727,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      658.24,
      533.47,
      764.14
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damages caused by temporary localized strong winds and lightning during thundershowers.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      6.0,
      12.0
    ]
  },
