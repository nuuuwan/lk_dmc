    ]
  },
  {
    "page_number": 0,
    "bbox": [
      217.13,
      524.11,
      419.16,
      537.07
    ],
    "text": "Issued at 04.00 p.m. on 08 May 2026.",
    "fonts": [
      "Calibri-Bold"
    ],
    "sizes": [
      12.0,
      12.960000038146973
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      539.95,
      554.52,
      595.39
    ],
    "text": "Due to the low-level atmospheric disturbance in the vicinity of Sri Lanka, the prevailing showery condition over the island is expected to continue during the next few days",
    "fonts": [
      "Calibri-Bold"
    ],
    "sizes": [
      9.0,
      12.0,
      12.960000038146973
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      598.93,
      456.5,
      619.27
    ],
    "text": "Showers or thundershowers will occur at most places of the island after 1.00 pm.",
    "fonts": [
      "Calibri",
      "Calibri-Bold",
      "Iskoola Pota"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      622.54,
      552.53,
      658.63
    ],
    "text": "Heavy falls above 100 mm are likely at some places in Western, Sabaragamuwa, Central, Uva, North-western provinces and in Galle and Matara districts.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      3.9600000381469727,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      662.29,
      513.41,
      683.83
    ],
    "text": "Showers are likely in the Western, Southern and Northern provinces during the morning too.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      6.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      692.14,
      555.04,
      731.62
    ],
    "text": "Misty conditions can be expected at some places in Central, Sabaragamuwa and Uva provinces and in Kurunegala district during the early hours of the morning.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      0.9599999785423279,
      5.039999961853027,
      9.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      735.52,
      554.47,
      954.84
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damages caused by temporary localized strong winds and lightning during thundershowers.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      6.960000038146973,
      11.039999961853027,
      12.0
    ]
  },
