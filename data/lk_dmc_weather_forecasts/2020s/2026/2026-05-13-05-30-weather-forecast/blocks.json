    "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82 \u0d9a\u0dcf \u0dc0\u0da7 \u0d8a\u0dc3 \u0db1\u0dca\u200d\u0dba \u0daf\u0dd9\u0daf\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0dd2\u0dc4\u0dd2\u0da7 \u0d87\u0dad\u0dd2 \u0d85\u0da9\u0dd4 \u0db4\u0dd3\u0da9\u0db1\u0dca\u200d\u0dba \u0d9a\u0dcf\u0dbd\u0d82 \u0db4\u0dba \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dc0\u0dad\u0dd3. \u0daf\u0dd9\u0db8\u0dcf\u0db8\u0dcf \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0dba \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0daf\u0dd2\u0db1\u0dca\u200d\u0dba \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba \u0dad\u0dd4\u0dc5 \u0d86\u0dc3\u0db1\u0dca\u0db1\u0dca\u200d\u0dba\u0dc0 \u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0daf\u0dd9\u0daf\u0dc3\u0da7 \u0d9c\u0db8\u0dcf\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dcf\u0da7 \u0d89\u0da9 \u0d87\u0dad. \u0d91\u0dba \u0daf\u0dd0\u0db1\u0dca\u200d\u0dba\u0da7 10.1N \u0dc3\u0dc4\u0dcf 83.5E \u0d86\u0dc3\u0db1\u0dca\u0db1\u0dca\u200d\u0dba\u0daf\u0dd9\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0da7 \u0d87\u0dad. \u0daf\u0dd9\u0db8\u0dcf\u0db8\u0dcf \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0daf\u0dd9\u0dda \u0db6\u0dbd\u0d82\u0db4\u0dd1\u0db8\u0dcf \u0daf\u0dd9\u0dc4\u0dcf\u0dda\u0dad\u0dd4\u0daf\u0dd9\u0dc0\u0db1\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0daf\u0dd2\u0db1\u0dca\u200d\u0dba\u0dc0\u0dbd\u0d82\u0daf\u0dd3 \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0dca\u200d\u0dba \u0dc0\u0da7 \u0dc0\u0db1\u0dca\u200d\u0dba \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dd9\u0daf\u0dca\u0dc1\u0dca\u200d\u0dc0\u0dbd\u0d82 \u0dc3\u0dd4\u0dc5\u0daf\u0dd9\u0dda \u0daf\u0dd9\u0dda\u0d9c\u0dba \u0dc3\u0dc4\u0dcf \u0dc0\u0dd0\u0dc3\u0dd2 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd2\u0dba \u0dc4\u0dcf\u0dd0\u0d9a\u0dcf. \u0dc4\u0db8\u0dca \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dca\u200d\u0dc4\u0dba\u0db1\u0dca \u0d9a\u0dcf\u0dbd\u0d9c\u0dd4\u0dab \u0dc0\u0dd2\u0daf\u0dba\u0dcf \u0dc4\u0daf\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0dc4\u0db8\u0dca\u0db1\