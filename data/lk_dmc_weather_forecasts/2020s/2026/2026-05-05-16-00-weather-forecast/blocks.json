      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      14.039999961853027
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      217.13,
      577.15,
      419.16,
      590.11
    ],
    "text": "Issued at 04.00 p.m. on 05 May 2026.",
    "fonts": [
      "Calibri,Bold"
    ],
    "sizes": [
      12.0,
      12.960000038146973
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      592.12,
      554.46,
      649.39
    ],
    "text": "The Intertropical Convergence Zone (where winds from the Northern Hemisphere and Southern Hemisphere converge) affects the island\u2019s weather. As a result, an increase in rainfall is expected over the island from tomorrow (06).",
    "fonts": [
      "Calibri,Bold"
    ],
    "sizes": [
      9.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      652.81,
      387.26,
      690.22
    ],
    "text": "Tonight: Showers or thundershowers will occur at most places of the island.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      693.13,
      555.05,
      728.14
    ],
    "text": "Fairly heavy falls above 75 mm are likely at some places in Western, Sabaragamuwa, Southern, Uva, Northern and Eastern provinces and in Polonnaruwa district.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      3.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      731.44,
      456.5,
      768.82
    ],
    "text": "Tomorrow: Showers or thundershowers will occur at most places of the island after 1.00 pm.",
    "fonts": [
      "Calibri",
      "Calibri,Bold",
      "Iskoola Pota"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      772.12,
      554.89,
      809.5
    ],
    "text": "Cloudy skies will prevail over the Western, Sabaragamuwa, Central, Southern and Uva provinces and in Ampara district. Morning showers are also expected in these areas.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      817.66,
      555.0,
      850.18
    ],
    "text": "Heavy falls above 100 mm are likely at some places in Sabaragamuwa, Central and Uva provinces and in Ampara, Batticaloa, Galle, Matara and Polonnaruwa districts.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      0.9599999785423279,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      853.96,
      555.03,
      892.32
    ],
    "text": "Misty conditions can be expected at some places in Central, Sabaragamuwa and Uva provinces during the early hours of the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      6.0,
      9.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      896.1,
      554.47,
      952.68
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damages caused by temporary localized strong winds and lightning during thundershowers.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      6.960000038146973,
      12.0
    ]
  },
