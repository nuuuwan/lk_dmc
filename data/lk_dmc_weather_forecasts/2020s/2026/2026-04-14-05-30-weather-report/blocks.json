  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      496.57,
      533.93,
      533.95
    ],
    "text": "Fairly heavy falls above 50 mm are likely at some places in Western, Sabaragamuwa and Central provinces and in Galle and Matara districts.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      540.82,
      533.93,
      574.63
    ],
    "text": "Misty conditions can be expected at some places in Central, Sabaragamuwa and Uva provinces and in Galle, Matara and Vavuniya districts during the early hours of the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      2.0399999618530273,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      577.93,
      533.76,
      615.31
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damages caused by temporary localized strong winds and lightning during thundershowers.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
