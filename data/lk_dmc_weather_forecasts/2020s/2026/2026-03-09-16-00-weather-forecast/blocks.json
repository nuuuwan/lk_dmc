    ],
    "text": "\u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0db4\u0dc5\u0dcf\u0dad\u0dda\u0dda \u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dd4\u0dab\u0dcf\u0db8\u0dbd\u0dba \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dad\u0dda\u0dda \u0dc0\u0dd0\u0dc3\u0dd2 \u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dc0\u0dbd\u0dca\u0db4\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a. \u0dc3\u0dca\u0dad\u0dca\u200d\u0db6\u0dbb\u0d9c\u0db8\u0dd4\u0dc0 \u0db4\u0dc5\u0dcf\u0dad\u0dda\u0dda \u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0dc3\u0dca\u0dad\u0dca\u200d\u0dc4 \u0db1\u0dd4\u0dc0\u0dbb\u0d91\u0dc5\u0dd2\u0dba \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dc0\u0dbd\u0dda \u0db4\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dc0\u0dbb\u0dd4 2.00 \u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0 \u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dae\u0dcf\u0db1 \u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dc0\u0dbd\u0dca\u0db4\u0dba\u0d9a \u0dc0\u0dd0\u0dc3\u0dd2 \u0dad\u0dc4\u0ddd \u0d9c\u0dd2\u0d9c\u0dd4\u0dbb\u0dd4\u0db8\u0dca \u0dc3\u0dca\u0dad\u0dca\u200d\u0dc4\u0dd2\u0dad \u0dc0\u0dd0\u0dc3\u0dd2 \u0d87\u0dad\u0dd2\u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a. \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0dad\u0db1\u0dca \u0d85\u0dad\u0db1\u0d9a\u0dd4\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dda\u0dc1\u0dc0\u0dbd \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc0\u0dc1\u0dad\u0dba\u0db1\u0dca \u0dc0\u0dd2\u0dba\u0dbd\u0dd2 \u0d9a\u0dcf\u0dbd\u0d9c\u0dd4\u0dab \u0dad\u0dda\u0dda\u0dc0\u0dba\u0d9a\u0dca \u0db4\u0dc0\u0dad\u0dd3. \u0db6\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0db1\u0dcf\u0dc4\u0dd2\u0dbb, \u0db8\u0db0\u0dba\u0db8, \u0dc3\u0dca\u0dad\u0dca\u200d\u0db6\u0dbb\u0d9c\u0db8\u0dd4\u0dc0, \u0d8c\u0dc0 \u0dc3\u0dca\u0dad\u0dca\u200d\u0dc4 \u0dc0\u0dba\u0db9 \u0db4\u0dc5\u0dcf\u0dda\u0dc0\u0dbd\u0dda \u0d85\u0db1\u0dd4\u0dbb\u0dcf\u0db0\u0db4\u0dd4\u0dbb, \u0db8\u0db1\u0dca\u0db1\u0dcf\u0dbb\u0db8, \u0d9c\u0dcf\u0dbd\u0dca\u0dbd \u0dc3\u0dca\u0dad\u0dca\u200d\u0dc4 \u0db8\u0dcf\u0dad\u0dbb \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dc0\u0dbd\u0dda \u0d87\u0dad\u0dd0\u0db8\u0dca \u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dae\u0dcf\u0db1\u0dc0\u0dbd \u0d85\u0dc5\u0dd4\u0dba\u0db8\u0dca \u0d9a\u0dcf\u0dbd\u0dad\u0dda\u0daf\u0dd3 \u0db8\u0dd3\u0daf\u0dd4\u0db8\u0dca \u0dc3\u0dca\u0dad\u0dca\u200d\u0dc4\u0dd2\u0dad \u0dad\u0dda\u0dda\u0dc0\u0dba\u0d9a\u0dca \u0db4\u0dd0\u0dc0\u0dad\u0dd2\u0dba \u0dc4\u0dd0\u0d9a.",
