      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      571.93,
      435.14,
      592.27
    ],
    "text": "A few showers will occur in Northern province and in Anuradhapura district.",
    "fonts": [
      "Calibri",
      "Iskoola Pota"
    ],
    "sizes": [
      5.039999961853027,
      12.0
