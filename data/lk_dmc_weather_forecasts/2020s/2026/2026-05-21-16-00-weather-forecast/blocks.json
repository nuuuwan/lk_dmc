    "page_number": 0,
    "bbox": [
      58.56,
      595.3,
      538.35,
      630.19
    ],
    "text": "Showers or thundershowers may occur at a few places in Uva province and in Ampara and Batticaloa districts after 2.00 pm.",
    "fonts": [
      "Calibri",
      "Iskoola Pota"
    ],
    "sizes": [
      3.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      633.46,
      538.3,
      686.38
    ],
    "text": "Fairly strong winds about (35-45) kmph can be expected at times over Western slopes of the central hills, Northern, North-central, North-western and Southern provinces and in Trincomalee district.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      3.9600000381469727,
      12.0
    ]
  },
