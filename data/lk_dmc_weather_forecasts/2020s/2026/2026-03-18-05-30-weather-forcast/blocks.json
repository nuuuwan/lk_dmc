    "bbox": [
      67.58,
      576.28,
      444.41,
      600.43
    ],
    "text": "A few showers may occur over the eastern coastal areas during the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
