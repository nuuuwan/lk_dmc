  {
    "page_number": 0,
    "bbox": [
      58.32,
      514.3,
      533.4,
      550.39
    ],
    "text": "Atmospheric conditions will be favorable for afternoon thundershowers in most parts of the island over the next few days from tomorrow (02 April).",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      3.9600000381469727,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      554.44,
      533.94,
      595.39
    ],
    "text": "Showers or thundershowers will occur at several places in Western, Central, Sabaragamuwa, Southern, Uva, North-western and North-central provinces after 2.00 p.m.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      599.32,
      534.05,
      640.27
    ],
    "text": "Fairly heavy falls above 50 mm are likely at some places in Western, Central and Sabaragamuwa provinces and in Kurunegala district.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      644.2,
      517.13,
      668.38
    ],
    "text": "A few showers may occur at Ampara, Batticaloa and Hambantota districts in the morning too.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      672.31,
      534.02,
      713.26
    ],
    "text": "Misty conditions can be expected at some places in Central, Sabaragamuwa and Uva provinces during the early hours of the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
