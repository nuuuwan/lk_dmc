    "text": "\u0d9a\u0db1\u0dca\u0d9a\u0dc3\u0db1\u0dca\u0dad\u0dd4\u0d9c\u0dbb\u0dca \u0dc3\u0dd2\u0da7 \u0db4\u0dd4\u0dad\u0dca\u0dad\u0dbd\u0db8, \u0d9c\u0d9a\u0dcf\u0dc5\u0db9, \u0dd9\u0dcf\u0dbd\u0dca\u0dbd \u0dc3\u0dc4 \u0dc4\u0dda\u0db6\u0db1\u0dca\u0d9c\u0dad\u0dcf\u0da7 \u0dc4\u0dbb\u0dc4\u0dcf \u0d9c\u0dd9\u0dcf\u0dad\u0dd4\u0dc0\u0dd2\u0dbd\u0dca \u0dd9\u0d9a\u0dca\u0dc0\u0ddc \u0db6\u0dc0\u0dbb\u0dc5\u0da7 \u0d94\u0db6\u0dca\u0db6 \u0db1\u0dca \u0dc0\u0db1 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db6\u0dda\u0dc1 \u0dc0\u0dd2\u0da7\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0da7 \u0dbb\u0dc5\u0dd4 \u0db6\u0dda. \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1 \u0dc0\u0da7\u0ddc \u0dc0\u0db1 \u0db6\u0dc3\u0dc3\u0dd4 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db6\u0dda\u0dc1 \u0db8\u0db3 \u0dc0\u0dc1\u0db6\u0dba\u0db1\u0dca \u0dbb\u0dc5\u0dd4 \u0dc0\u0dd2\u0dba \u0dd0\u0d9a. \u0db4\u0dd4\u0dad\u0dca\u0dad\u0dbd\u0db8 \u0dc3\u0dd2\u0da7 \u0d9c\u0d9a\u0dcf\u0dc5\u0db9, \u0dd9\u0dcf\u0dbd\u0dca\u0dbd \u0dc3\u0dc4 \u0dc4\u0dda\u0db6\u0db1\u0dca\u0d9c\u0dad\u0dcf\u0da7 \u0dc4\u0dbb\u0dc4\u0dcf \u0d9c\u0dd9\u0dcf\u0dad\u0dd4\u0dc0\u0dd2\u0dbd\u0dca \u0daf\u0d9a\u0dc0\u0dcf \u0d9c\u0dc0\u0dbb\u0dc5\u0da7 \u0d94\u0dda\u0d9c\u0db6\u0db1\u0dca \u0dc0\u0db1 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0d9c\u0dda\u0dc1\u0dc0\u0dbd \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0dbb\u0dc5 \u0d8b\u0dc3 \u0db8\u0dd3\u0da7\u0dbb\u0dca (2.0 \u2013 2.5) \u0d9a \u0dd9\u0db8\u0dab \u0d89\u0dc4\u0dc5 \u0dba\u0dcf\u0d9c\u0dda \u0dc4\u0dd0\u0d9a\u0dd2\u0dba\u0dcf\u0dc0\u0d9a \u0dd9\u0dc0\u0dad\u0dd3. (\u0db6\u0db8\u0dba \u0db6\u0d9c\u0ddc\u0da9\u0db6\u0dd2\u0db8\u0da7 \u0d91\u0db1 \u0dbb\u0dc5 \u0d8b\u0dc3 \u0db6\u0db1\u0ddc\u0db6\u0dda). \u0d9c\u0dd2\u0d9c\u0dd4\u0dbb\u0dd4\u0dda \u0dc3\u0dc4\u0dd2\u0dad \u0dc0\u0dd0\u0dc3\u0dd2 \u0d87\u0dad\u0dd2 \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0d91\u0db8 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0db4\u0dca\u200d\u