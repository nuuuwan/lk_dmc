    "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0d85\u0dc1\u0dca\u200d\u0dbb\u0dd2\u0dad\u0dc0 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0db4\u0dc4\u0dc5 \u0dc0\u0dcf\u0dba\u0dd4\u0dbd \u0ddd\u0dbd\u0dd3\u0dba \u0d9a\u0dd0\u0dc5\u0db9\u0dd2\u0dbd\u0dd2 \u0dc3\u0dca\u0dc0\u0db7\u0dcf\u0dc0\u0dba, \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0db4\u0dd0\u0dba 48 \u0dad\u0dd4\u0dbd\u0daf\u0dd3 \u0d85\u0da9\u0dd4 \u0db4\u0dd3\u0da9\u0db1 \u0d9a\u0dbd\u0dcf\u0db4\u0dba\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a. \u0dbd\u0dd9\u0dd9 \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0dbd\u0dda \u0db6\u0dbd\u0db4\u0dd1\u0dd9 \u0dbd\u0dc4\u0dca\u0dad\u0dd4\u0dbd\u0dc0\u0dda \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0daf\u0dd2\u0db1\u0dc0\u0dbd\u0daf\u0dd3 \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1 \u0dc0\u0da7\u0dcf\u0dc0\u0db1 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0dbd\u0daf\u0dca\u0dc1\u0dc0\u0dbd \u0dc3\u0dd4\u0dc5\u0dbd\u0dda \u0dbd\u0dda \u0dba \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a.",
