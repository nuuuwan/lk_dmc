  {
    "page_number": 0,
    "bbox": [
      58.32,
      569.68,
      534.05,
      645.55
    ],
    "text": "Due to the influence of the above system, Showers or thundershowers will occur at times and cloudy skies are expected in Western, Sabaragamuwa, Central, North-western and Northern provinces and in Galle and Matara districts. Fairly heavy showers above 75 mm are likely at some places in these areas.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      9.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      649.21,
      359.06,
      670.78
    ],
    "text": "Several spells of showers will occur in Anuradhapura district.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      6.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      674.95,
      460.37,
      698.86
    ],
    "text": "Showers or thundershowers may occur at several places elsewhere after 1.00 pm.",
    "fonts": [
      "Calibri",
      "Iskoola Pota"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      702.01,
      533.62,
      757.9
