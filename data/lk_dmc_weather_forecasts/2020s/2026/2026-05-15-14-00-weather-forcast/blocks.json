    "bbox": [
      61.34,
      316.61,
      153.69,
      328.61
    ],
    "text": "Condition of Rain:",
    "fonts": [
      "Calibri-Bold"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      61.34,
      337.97,
      557.81,
      383.57
    ],
    "text": "Showers or thundershowers will occur at times in the sea areas off the coast extending from Mullaitivu to Galle via Kankasanthurai, Puttalam and Colombo. Showers or thundershowers will occur at several places elsewhere around the island in the evening or night.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      12.0
    ]
  },
  {
