    "sizes": [
      14.039999961853027
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      208.85,
      497.83,
      410.88,
      510.79
    ],
    "text": "Issued at 04.00 p.m. on 12 May 2026.",
    "fonts": [
      "Calibri,Bold"
    ],
    "sizes": [
      12.0,
      12.960000038146973
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      511.78,
      538.34,
      574.99
    ],
    "text": "The low pressure area located northeast of the Sri Lanka likely to move nearly northwards during next few days. Due to the influence of this system, the current rainy conditions in the island are expected to continue for the next few days.",
    "fonts": [
      "Calibri,Bold"
    ],
    "sizes": [
      3.9600000381469727,
      9.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      578.65,
      535.73,
      617.11
    ],
    "text": "Showers or thundershowers will occur at times in Western, Sabaragamuwa, Central, North-western and Northern provinces and in Anuradhapura, Trincomalee, Galle and Matara districts.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      6.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      620.77,
      458.69,
      642.43
    ],
    "text": "Showers or thundershowers will occur at other places of the island after 1.00 pm.",
    "fonts": [
      "Calibri",
      "Iskoola Pota"
    ],
    "sizes": [
      6.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      646.09,
      535.85,
      684.46
    ],
    "text": "Heavy falls above 100 mm are likely at some places in Western, Sabaragamuwa, Central, North-western, and Uva provinces and in Ampara, Batticaloa, Galle and Matara districts.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      6.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      688.24,
      537.86,
      788.5
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damage caused by temporary localized strong winds and lightning during thundershowers.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      6.0,
      11.039999961853027,
      12.0
    ]
  },
