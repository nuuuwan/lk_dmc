    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      512.11,
      533.9,
      544.63
    ],
    "text": "Due to the low-level atmospheric disturbance in the vicinity of Sri Lanka, the prevailing showery condition over the island is expected to continue during the next few days",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      0.9599999785423279,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      548.05,
      456.53,
      568.51
    ],
    "text": "Showers or thundershowers will occur at most places of the island after 1.00 pm.",
    "fonts": [
      "Calibri",
      "Calibri,Bold",
      "Iskoola Pota"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      571.66,
      533.9,
      607.87
    ],
    "text": "Showers are likely in the Western, North-western and Northern provinces and in Trincomalee, Galle and Matara districts during the morning too.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      3.9600000381469727,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      616.03,
      533.93,
      648.55
    ],
    "text": "Fairly heavy falls above 75 mm are likely at some places in Sabaragamuwa, Central, Uva, Southern and North-central provinces.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      0.9599999785423279,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      651.88,
      533.5,
      689.26
    ],
    "text": "Misty conditions can be expected at some places in Central, Sabaragamuwa and Uva provinces during the early hours of the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      5.039999961853027,
      9.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      693.04,
      533.34,
      766.54
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damages caused by temporary localized strong winds and lightning during thundershowers.",
