    ],
    "sizes": [
      3.0,
      12.479999542236328
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      205.73,
      481.51,
      386.66,
      493.51
    ],
    "text": "Issued at 2.00 p.m. on 11 April 2026",
    "fonts": [
      "Calibri,Bold"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      496.93,
      534.05,
      551.11
    ],
    "text": "Showers or thundershowers will occur at several places in Western, Sabaragamuwa, Central, Southern, North-western and Uva provinces and in Ampara, Batticaloa and Anuradhapura districts after 2.00 p.m.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      554.02,
      534.04,
      589.03
    ],
    "text": "Fairly heavy falls above 50 mm are likely at some places in Western and Sabaragamuwa provinces and in Kandy, Nuwara-Eliya, Galle and Matara districts.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      3.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      592.18,
      378.74,
      611.47
    ],
    "text": "Mainly dry weather will prevail over the other parts of the island.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      3.9600000381469727,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      614.89,
      534.05,
      652.15
    ],
    "text": "Misty conditions can be expected at some places in Central, Sabaragamuwa and Uva provinces and in Galle and Matara districts during the early hours of the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      655.45,
      533.62,
      691.54
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damages caused by temporary localized strong winds and lightning during thundershowers.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      3.9600000381469727,
      12.0
    ]
  },
  {
