    "bbox": [
      58.56,
      567.25,
      359.3,
      588.79
    ],
    "text": "Several spells of showers will occur in Anuradhapura district.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      6.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      592.84,
      533.9,
      633.67
    ],
    "text": "Showers or thundershowers may occur at a few places in Uva and Eastern provinces and in Polonnaruwa district after 1.00 pm.",
