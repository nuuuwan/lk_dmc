  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      500.26,
      538.37,
      546.55
    ],
    "text": "The low-pressure area located northeast of the Sri Lanka, still persist. The Department of Meteorology is continuously monitoring the behavior, development and path of the system.",
    "fonts": [
      "Calibri-Bold"
    ],
    "sizes": [
      3.9600000381469727,
      9.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      550.72,
      538.37,
      626.59
    ],
    "text": "Due to the influence of the above system, Showers or thundershowers will occur at times and cloudy skies are expected in Western, Sabaragamuwa, Central, North-western and Northern provinces and in Galle and Matara districts. Fairly heavy showers about 75 mm are likely at some places in these areas.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      9.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      630.25,
      359.3,
      651.79
    ],
    "text": "Several spells of showers will occur in Anuradhapura district.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      6.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      655.99,
      538.37,
      679.9
    ],
    "text": "Showers or thundershowers may occur at a few places in Uva and Eastern provinces after 1.00 pm.",
    "fonts": [
      "Calibri",
      "Iskoola Pota"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      683.05,
      537.86,
      789.46
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damage caused by temporary localized strong winds and lightning during thundershowers.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      3.0,
      12.0
    ]
  },
