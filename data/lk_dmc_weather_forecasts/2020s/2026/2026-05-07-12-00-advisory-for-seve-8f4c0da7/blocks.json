    "text": "\u0d86\u0dbb\u0d9a\u0dca\u0dd2\u0dad \u0dc0\u0d9c\u0dcf\u0da9\u0db1\u0dd0\u0d9c\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0dc0\u0dc4\u0ddd \u0dc3\u0d82\u0dc0\u0dd8\u0dad \u0dc0\u0dcf\u0dc4\u0db1\u0dba\u0d9a\u0dca \u0dd4\u0dc5 \u0dbb\u0dd0\u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1\u0dca\u0dad\u0db1. \uf0b7 \u0d9a\u0dd4\u0db9\u0dd4\u0dbb\u0dd4, \u0dc0\u0dad\u0dca \u0dc0\u0dd4, \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0db4\u0dd2\u0da7\u0dd2 \u0dc0\u0db8\u0db1\u0dca\u0dad\u0db8 \u0da2\u0dbd\u0dcf\u0dc1 \u0dc0\u0dd0\u0db1\u0dd2 \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0dc3\u0dca\u0dae\u0db1 \u0dc0\u0dbd \u0dbb\u0dd0\u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd3\u0dc0\u0db8\u0db1\u0dca\u0dad \u0dc0\u0dbd\u0d9a\u0dd2\u0db1\u0dca\u0dad\u0db1. \uf0b7 \u0dbb\u0dd0\u0dc4\u0dd0\u0db1\u0dca\u0dad \u0dc3\u0dc4\u0dd2\u0dad \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1 \u0dc3\u0dc4 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba\u0da7 \u0dc3\u0dda\u0db6\u0db1\u0dca\u0dad\u0db0\u0dca\u200d \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dc0\u0dba\u0db1\u0dca\u0dad \u0dc0\u0dbd\u0d9a\u0dd2\u0db1\u0dca\u0dad\u0db1. \uf0b7 \u0db6\u0dba\u0dd2\u0dc3\u0dd2\u0d9a\u0dbd\u0dca, \u0da7\u0dca\u200d\u0dbb\u0dd0\u0d9a\u0dca\u0da7\u0dbb\u0dca \u0dc3\u0dc4 \u0dc0\u0db6\u0ddd\u0da7\u0dca\u0da7\u0dd4 \u0dc0\u0dd0\u0db1\u0dd2 \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0dc0\u0dcf\u0dc4\u0db1 \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dc0\u0dba\u0db1\u0dca\u0dad \u0dc0\u0dbd\u0d9a\u0dd2\u0db1\u0dca\u0dad\u0db1. \uf0b7 \u0dad\u0daf \u0dc3\u0dd4\u0dc5\u0d82 \u0dc0\u0dc4\u0dca\u0dd4\u0dc0\u0dc0\u0db1\u0dca\u0dad \u0d9c\u0dc3\u0dca \u0dc4\u0dcf \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0dbb\u0dd0\u0dc4\u0dd0\u0db1\u0dca\u0dad \u0db6\u0dd2\u0db8 \u0d87\u0daf \u0dc0\u0dd0\u0da7\u0dd3\u0db8\u0da7 \u0d89\u0da9 \u0d87\u0dad\u0dd2 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca\u0dad \u0d92 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0daf\u0dc0 \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dbd\u0dd2\u0d