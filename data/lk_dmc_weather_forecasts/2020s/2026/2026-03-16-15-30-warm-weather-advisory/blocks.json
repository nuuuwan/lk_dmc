    "text": "\u0dc0\u0dc0\u0dd4\u0db1\u0dd2\u0dba\u0dcf\u0dc0 \u0daf\u0dd2\u0dc3\u0dca\u0dd2\u0d9a\u0dca\u0d9a \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd2\u0db8\u0dc3\u0dd2\u0dbd\u0dd2\u0db8\u0dad\u0dca\u0dad \u0dc0\u0db1\u0dca\u0dad\u0db1! \u0db6\u0dc3\u0dca\u0db1\u0dcf\u0dc4\u0dd2\u0dbb, \u0dc3\u0db6\u0dbb\u0d9c\u0db8\u0dd4\u0dc0, \u0daf\u0d9a\u0dd4\u0dab\u0dd4, \u0d8b\u0dad\u0dd4\u0dbb\u0dd4\u0db8\u0dd0\u0daf \u0dc3\u0dc4 \u0dc0\u0dba\u0db9 \u0db4\u0dc5\u0dcf\u0dad\u0dca\u0dad\u0dc0\u0dbd\u0dad\u0dca\u0dad \u0dc0\u0db8\u0dcf\u0db1\u0dbb\u0dcf\u0d9c\u0dbd, \u0db8\u0db1\u0dca\u0dad\u0db1\u0dcf\u0dbb\u0db8 \u0dc3\u0dc4 \u0dc0\u0dc0\u0dd4\u0db1\u0dd2\u0dba\u0dcf\u0dc0 \u0daf\u0dd2\u0dc3\u0dca\u0dd2\u0d9a\u0dca\u0d9a\u0dc0\u0dbd\u0dad\u0dca\u0dad \u0d87\u0dad\u0dd0\u0db8\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dda\u0dc1\u0dc0\u0dbd \u0d8b\u0dab\u0dd4\u0dc3\u0dd4\u0db8\u0dca \u0daf\u0dbb\u0dca\u0dc1\u0d9a\u0dba, \u0d91\u0db1\u0db8\u0dca \u0db8\u0dd2\u0db1\u0dd2\u0dc3\u0dca \u0dc3\u0dd2\u0dbb\u0dd4\u0dbb\u0da7 \u0daf\u0dd0\u0dc0\u0db1\u0db1 \u0d8b\u0dab\u0dd4\u0dc3\u0dd4\u0db8 \u201c\u0d85\u0dc0\u0db0\u0dca\u200d\u0dcf\u0db1\u0dba \u0dc0\u0dba\u0dcf\u0db8\u0dd4 \u0d9a\u0dbd \u0dba\u0dd4\u0dd4\u201d \u0db8\u0da7\u0dca\u0da7\u0db8\u0d9a \u0db4\u0dd0\u0dc0\u0dad\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2\u0dba\u0dd2.",
