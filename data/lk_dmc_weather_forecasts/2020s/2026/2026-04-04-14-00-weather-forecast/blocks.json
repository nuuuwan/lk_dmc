    "bbox": [
      58.32,
      489.82,
      533.93,
      525.91
    ],
    "text": "Showers or thundershowers will occur at several places in Western, Central, Sabaragamuwa, Southern, Uva, and Eastern provinces and in Polonnaruwa district after 2.00 p.m.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      3.9600000381469727,
      12.0
    ]
  },
  {
