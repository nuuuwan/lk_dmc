  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      571.33,
      534.05,
      625.63
    ],
    "text": "Misty conditions can be expected at some places in Western, Central, Sabaragamuwa, Uva and North-central provinces and in Jaffna and Kurunegala districts during the early hours of the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
