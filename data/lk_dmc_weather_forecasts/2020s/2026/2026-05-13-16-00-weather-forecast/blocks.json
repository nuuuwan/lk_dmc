  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      528.82,
      537.91,
      608.71
    ],
    "text": "The low pressure area located northeast of the Sri Lanka, still persist. this system is expected to move away from Sri Lanka and gradually weaken during the next 48 hours. Due to the influence of this system, the prevailing showery weather condition over the island is expected to continue further during the next two days.",
    "fonts": [
      "Calibri-Bold"
    ],
    "sizes": [
      3.9600000381469727,
      9.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      612.73,
      537.88,
      652.27
    ],
    "text": "Showers or thundershowers will occur at times in Western, Sabaragamuwa, Central, Southern, North-western and Northern provinces and in Anuradhapura district.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      6.960000038146973,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      655.96,
      535.73,
      694.42
    ],
    "text": "Heavy falls above 100 mm are likely at some places in Western, Sabaragamuwa, Central and North-western provinces and in Galle and Matara districts.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      6.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      698.32,
      436.46,
      721.06
    ],
    "text": "Showers or thundershowers will occur elsewhere of the island after 1.00 pm.",
    "fonts": [
      "Calibri",
      "Iskoola Pota"
    ],
    "sizes": [
      6.960000038146973,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      729.73,
      537.86,
      780.22
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damage caused by temporary localized strong winds and lightning during thundershowers.",
