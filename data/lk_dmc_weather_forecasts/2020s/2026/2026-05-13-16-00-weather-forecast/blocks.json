    "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0d8a\u0dc3\u0dcf\u0db1\u0dca\u200d \u0daf\u0dd9\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dcf \u0d87\u0dad\u0dd2 \u0d85\u0da9\u0dd4 \u0db4\u0dd3\u0da9\u0db1\u0dca\u200d \u0d9a\u0dbd\u0dcf\u0db4\u0dba, \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dc0\u0dad\u0dd3. \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0db4\u0dd0\u0dba 48 \u0dad\u0dd4\u0dbd \u0d91\u0db8 \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0dba \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0daf\u0dc0\u0db1\u0dca \u0d89\u0dc0\u0dad\u0da7 \u0d9c\u0db8\u0db1\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca, \u0d9a\u0dca\u200d\u0dbb\u0db8\u0daf\u0dba\u0db1\u0dca \u0daf\u0dd4\u0dbb\u0dca\u0dc0\u0dbd \u0dc0\u0db1\u0dd4 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d85\u0daf\u0dda\u0d9a\u0dca\u0dc2\u0dcf \u0daf\u0d9a\u0daf\u0dbb\u0dca. \u0daf\u0db8\u0db8 \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0daf\u0dda \u0db6\u0dbd\u0db4\u0dd1\u0db8 \u0daf\u0dc4\u0dda\u0dad\u0dd4\u0daf\u0dc0\u0db1\u0dca \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0daf\u0db1\u0dca \u0dd9\u0dd0\u0db1\u0dca\u200d\u0da7 \u0db4\u0dc0\u0dad\u0dd2\u0db1\u0dca\u200d \u0dc0\u0dd0\u0dc3\u0dd2 \u0dc3\u0dc4\u0dd2\u0dad \u0d9a\u0dcf\u0dbd\u0d9c\u0dd4\u0dab \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0daf\u0dd2\u0db1\u0dca\u200d 2 \u0dad\u0dd4\u0dbd\u0daf\u0dd3\u0dd9, \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dc0\u0dad\u0dd2\u0db1\u0dd4 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db6\u0dbd\u0dcf\u0daf\u0db4\u0dcf\u0daf\u0dbb\u0dcf\u0dad\u0dca\u0dad\u0dd4\u0daf\u0dda.",
