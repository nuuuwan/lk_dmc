      11.039999961853027
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      61.32,
      718.54,
      429.89,
      729.58
    ],
    "text": "Showers or thundershowers will occur at times in the sea areas around the island.",
    "fonts": [
