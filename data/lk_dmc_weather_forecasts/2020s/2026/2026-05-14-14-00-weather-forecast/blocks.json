\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0d85\u0db1\u0dcf\u0dc0\u0dd0\u0d9a\u0dd2 \u0dc3 \u0db1\u0dd2\u0dc4\u0dda\u0daf\u0db1 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0d85\u0dc0\u0db0\u0dca\u200d\u0dcf\u0db1\u0dc4\u0dba\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0\u0db1 \u0dc4\u0dbd\u0dc3 \u0db0\u0dd3\u0dc0\u0dbb \u0dc3 \u0db1\u0dcf\u0dc0\u0dd4\u0d9a \u0db4\u0dca\u200d\u0dbb\u0da2\u0dcf\u0dc0\u0dc4\u0d9c\u0db1\u0dca \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0db1\u0dd4 \u0dbd\u0dd0\u0dc4\u0dda. \u0dc0\u0dd0\u0dc3\u0dd2 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba:",
