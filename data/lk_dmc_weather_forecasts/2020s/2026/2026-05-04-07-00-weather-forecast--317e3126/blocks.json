    "text": "\u0dc0\u0dd0\u0dc3\u0dd2 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba: \u0db8\u0db1\u0dca\u0db1\u0ddc\u0dbb\u0db8 \u0dc3\u0dd2\u0da7 \u0db4\u0dd4\u0dad\u0dca\u0dad\u0dbd\u0db8, \u0db6\u0d9a\u0ddc\u0dc5\u0db9 ,\u0d9c\u0ddc\u0dbd\u0dca\u0dbd, \u0db8\u0dca \u0db1\u0dca\u0db6\u0dad\u0ddc\u0da7 \u0dbb \u0ddc \u0db6\u0db4\u0ddc\u0dad\u0dd4\u0dc0\u0dd2\u0dbd\u0dca \u0dd9\u0d9a\u0dca\u0dc0\u0ddc \u0db6\u0dc0\u0dbb\u0dc5\u0da7 \u0d94\u0db6\u0dca\u0db6 \u0db1\u0dca \u0dc0\u0db1 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db6\u0dda\u0dc1\u0dc0\u0dbd \u0dad\u0dd0\u0db1\u0dd2\u0db1\u0dca \u0dad\u0dd0\u0db1 \u0dc0\u0dd0\u0dc3\u0dd2 \u0db6 \u0ddd \u0d9c\u0dd2\u0d9c\u0dd4\u0dbb\u0dd4\u0db8\u0dca \u0dc3\u0dc4\u0dd2\u0dad \u0dc0\u0dd0\u0dc3\u0dd2 \u0d87\u0dad\u0dd2 \u0db6\u0dda. \u0dc3\u0dd4\u0dc5\u0d9f: \u0dc3\u0dd4\u0dc5\u0d82 \u0db1\u0dd2\u0dbb\u0dd2\u0dad \u0daf\u0dd2\u0dc1\u0ddc\u0db6\u0dc0\u0db1\u0dca \u0db8\u0ddc \u0d91\u0db1 \u0d85\u0dad\u0dbb \u0dc3\u0dd4\u0dc5\u0d82 \u0db6\u0dda\u0d9c\u0dba \u0db4\u0dd0.\u0d9a\u0dd2.\u0db8\u0dd3. (25-35) \u0db4\u0db8\u0dab \u0db6\u0dda. \u0dbd\u0ddc\u0dc0\u0dad \u0dc3\u0dd2\u0da7 \u0db8\u0db1\u0dca\u0db1\u0ddc\u0dbb\u0db8 \u0dbb \u0ddc \u0d9a\u0db1\u0dca\u0d9a\u0dc3\u0db1\u0dca\u0dad\u0dd4\u0dbb\u0dba \u0dd9\u0d9a\u0dca\u0dc0\u0ddc \u0dc3 \u0db8\u0ddc\u0dad\u0dbb \u0dc3\u0dd2\u0da7 \u0db8\u0dca \u0db1\u0dca\u0db6\u0dad\u0ddc\u0da7 \u0dbb \u0ddc \u0db6\u0db4\u0ddc\u0dad\u0dd4\u0dc0\u0dd2\u0dbd\u0dca \u0dd9\u0d9a\u0dca\u0dc0\u0ddc \u0db6\u0dc0\u0dbb\u0dc5\u0da7 \u0d94\u0db6\u0dca\u0db6 \u0db1\u0dca \u0dc0\u0db1 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db6\u0dda\u0dc1\u0dc0\u0dbd \u0dc3\u0dd4\u0dc5\u0db6\u0dda \u0db6\u0dda\u0d9c\u0dba \u0dc0\u0dd2\u0da7\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0da7 \u0dd9\u0dd0.\u0d9a\u0dd2.\u0db8\u0dd3. (50-60) \u0db4\u0db8\u0dab \u0dd9\u0d9a\u0dca\u0dc0\u0ddc \u0d89 \u0dc5 \u0dba\u0ddc \u0dd0\u0d9a. \u0db8\u0dd4\u0dc4\u0dd4\u0d9c\u0dda \u0dc3\u0dca\u0dc0\u0db7\u0d