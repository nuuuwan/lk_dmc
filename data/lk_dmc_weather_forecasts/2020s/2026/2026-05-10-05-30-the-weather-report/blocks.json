  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      481.15,
      533.52,
      530.47
    ],
    "text": "The low-level atmospheric disturbance in the vicinity of Sri Lanka is likely to develop into a low-pressure area around 11th of May. Therefore, the prevailing showery conditions over the island are expected to continue during the next few days.",
    "fonts": [
      "Calibri,Bold"
    ],
    "sizes": [
      0.9599999785423279,
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      534.13,
      533.93,
      574.03
    ],
    "text": "Showers or thundershowers will occur at most places over the island, and cloudy skies are expected over the island.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      6.960000038146973,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      578.2,
      533.91,
      753.7
    ],
    "text": "Heavy falls above 100 mm are likely at some places in Western, Sabaragamuwa, Central, Southern, Uva, North-western and Northern provinces and in Anuradhapura district. The general public is kindly requested to take adequate precautions to minimize damage caused by temporary localized strong winds and lightning during thundershowers.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      9.0,
