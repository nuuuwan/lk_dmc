    "text": "\u0d8b\u0dab\u0dd4\u0dc3\u0dd4\u0db8\u0dca \u0d9a\u0dcf\u0dbd\u0d9c\u0dd4\u0dab \u0dad\u0dad\u0dca\u0dad\u0dad\u0dca\u0dad\u0dc0\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d85\u0dc0\u0dc0\u0dcf\u0daf\u0dcf\u0dad\u0dca\u0dad\u0db8\u0d9a \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dcf\u0dbd\u0d9c\u0dd4\u0dab \u0dc0\u0dd2\u0daf\u0dba\u0dcf \u0dc0\u0daf\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0dc0\u0db8\u0dca\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda, \u0dc3\u0dca\u0dc0\u0db7\u0dcf\u0dc0\u0dd2\u0d9a \u0dc0\u0dd2\u0db4\u0dad\u0dca\u0dad \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0db4\u0dd6\u0dbb\u0dca\u0dc0 \u0d85\u0db1\u0dd4\u0dbb\u0dd4 \u0d87\u0d9f\u0dc0\u0dd3\u0dc0\u0db8\u0dca \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca\u0dad 2026 \u0d85\u0dc0\u0dda\u0dbd\u0dca 13 \u0daf\u0dd2\u0db1\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dbd\u0d82\u0d9c\u0dd4 \u0dc0\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2, 2026 \u0d85\u0dc0\u0dda\u0dbd\u0dca 12 \u0daf\u0dd2\u0db1 \u0db4.\u0dc0. 03.30 \u0da7 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca\u0dad \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dd2.",
