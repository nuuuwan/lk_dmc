      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      588.49,
      538.14,
      643.75
    ],
    "text": "Misty conditions can be expected at some places in Central, Sabaragamuwa, North-western, North-central and Western provinces and in Galle and Matara districts during the early hours of the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      6.0,
