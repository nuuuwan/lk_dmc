  {
    "page_number": 0,
    "bbox": [
      58.56,
      523.57,
      538.37,
      560.95
    ],
    "text": "Fairly heavy showers above 75 mm can be expected at some places in Central, Sabaragamuwa and Uva provinces and in Ampara district.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
