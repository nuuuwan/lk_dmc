  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      590.17,
      538.2,
      627.43
    ],
    "text": "Fairly heavy falls above 50 mm are likely at some places in Western and Sabaragamuwa provinces and in Galle, Kandy and Nuwara-Eliya districts.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      5.039999961853027,
      12.0
