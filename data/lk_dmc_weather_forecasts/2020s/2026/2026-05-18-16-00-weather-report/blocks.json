    "bbox": [
      58.56,
      708.01,
      538.13,
      743.98
    ],
    "text": "Fairly strong winds about (30-40) kmph can be expected at times over Western slopes of the central hills, Northern, North-central and North-western provinces and in Hambantota district.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      3.9600000381469727,
