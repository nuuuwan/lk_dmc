  {
    "page_number": 0,
    "bbox": [
      58.32,
      479.39,
      550.47,
      551.47
    ],
    "text": "The low-level atmospheric disturbance was in the vicinity of Sri Lanka has developed into a low-pressure area and located to the northeast of the island according to the latest weather analysis based on May 11th morning. Therefore, the prevailing showery conditions over the island are expected to continue during the next few days.",
    "fonts": [
      "Calibri-Bold"
    ],
    "sizes": [
      6.0,
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      555.49,
      550.68,
      595.03
    ],
    "text": "Showers or thundershowers will occur at times in most parts of the island and Cloudy skies are expected.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      6.960000038146973,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      599.2,
      548.21,
      641.35
    ],
    "text": "Heavy falls above 100 mm are likely at some places in Western, Sabaragamuwa, Southern, North-western and Northern provinces and in Trincomalee district.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      9.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      645.25,
      550.38,
      937.56
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damage caused by temporary localized strong winds and lightning during thundershowers.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      6.960000038146973,
      12.0
    ]
  },
