  {
    "page_number": 0,
    "bbox": [
      58.32,
      461.29,
      533.98,
      533.35
    ],
    "text": "The low-level atmospheric disturbance in the vicinity of Sri Lanka is likely to develop into a low-pressure area around 11th of May. Therefore, the prevailing showery conditions over the island are expected to continue during the next few days. Cloudy skies are expected over most parts of the island.",
    "fonts": [
      "Calibri-Bold"
    ],
    "sizes": [
      6.0,
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      536.89,
      534.0,
      574.15
    ],
    "text": "Showers or thundershowers will occur at most places of the island after 1.00 pm. Heavy falls above 100 mm are likely at some places.",
    "fonts": [
      "Calibri",
      "Calibri-Bold",
      "Iskoola Pota"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      577.81,
      533.85,
      616.15
    ],
    "text": "Showers are likely in the Western, Southern, Eastern and Northern provinces during the morning too.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      6.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      620.17,
      534.04,
      743.98
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damage caused by temporary localized strong winds and lightning during thundershowers.",
    "fonts": [
      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      6.960000038146973,
      12.0
    ]
