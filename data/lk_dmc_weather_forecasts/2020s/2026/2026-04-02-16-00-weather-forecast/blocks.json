  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      483.88,
      555.05,
      515.47
    ],
    "text": "Atmospheric conditions will be favorable for afternoon thundershowers in most parts of the island.",
    "fonts": [
      "Calibri,Bold"
    ],
    "sizes": [
      5.039999961853027,
      9.960000038146973,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      518.77,
      553.25,
      539.35
    ],
    "text": "Showers or thundershowers will occur at several places in in most parts of the island after 2.00 p.m.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      543.01,
      555.05,
      581.47
    ],
    "text": "Fairly heavy falls about 75 mm are likely at some places in Central, Sabaragamuwa, Uva, North-central and Eastern provinces.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      6.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      584.77,
      485.57,
      605.23
    ],
    "text": "Showers may occur in Eastern province and in Hambantota district in the morning too.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      608.65,
      555.05,
      646.03
    ],
    "text": "Misty conditions can be expected at some places in Central, Sabaragamuwa, Uva and North-central provinces and in Kurunegala and Vavuniya districts during the early hours of the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      649.69,
      554.47,
      943.75
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damages caused by temporary localized strong winds and lightning during thundershowers.",
