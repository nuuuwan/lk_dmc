  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      518.53,
      534.03,
      555.91
    ],
    "text": "Showers or thundershowers will occur at several places in in most parts of the island after 2.00 p.m.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.32,
      559.57,
      531.41,
      598.03
    ],
    "text": "Fairly heavy falls about 75 mm are likely at some places in Central, Sabaragamuwa, Uva, North-central and Eastern provinces.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      6.0,
      12.0
    ]
