    ],
    "sizes": [
      6.0,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      58.56,
      751.0,
      554.98,
      956.76
    ],
    "text": "The general public is kindly requested to take adequate precautions to minimize damages caused by temporary localized strong winds and lightning during thundershowers. On the apparent northward relative motion of the sun, it is going to be directly over the latitudes of Sri Lanka during 05th to 15th of April in this year. The nearest areas of Sri Lanka over which the sun is overhead tomorrow (09th) are Chilaw, Bingiriya, Halmillawewa, Panduwasnuwara, Gokarella, Kawudupelella, Koppaveli and Kirankulam about 12:12 noon.",
    "fonts": [
      "Calibri",
