    "bbox": [
      58.56,
      461.35,
      538.37,
      525.43
    ],
    "text": "Issued at 04.00 p.m. on 16 April 2026. Showers or thundershowers will occur at several places in Western, Sabaragamuwa, Southern and Uva provinces and in Kandy and Nuwara-Eliya districts after 1.00 pm.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      12.0,
