    "text": "\u0d89\u0dc4\u0dad \u0d8b\u0dab\u0dd4\u0dc3\u0dd4\u0db8\u0dca \u0daf\u0dbb\u0dca\u0dc1\u0d9a\u0dba (Heat Index) \u0d9a\u0dcf\u0dbd\u0d9c\u0dd4\u0dab\u0dc0\u0dd2\u0daf\u0dba\u0dcf \u0dc0\u0daf\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0dc0\u0db8\u0dca\u0db1\u0dca\u0dad\u0dad\u0dd4\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca\u0dad \u0dc0\u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0d9c\u0dab\u0dd2\u0dad\u0db8\u0dba \u0d9a\u0dcf\u0dbd\u0d9c\u0dd4\u0dab \u0d85\u0db1\u0dcf\u0dc0\u0dd0\u0d9a\u0dd2 \u0d86\u0d9a\u0dd8\u0dad\u0dd2 \u0daf\u0dad\u0dca\u0dad \u0dc0\u0dd2\u0dc1\u0dbb\u0dc0\u0dda\u0dc2\u0dab \u0db8\u0d9c\u0dd2\u0db1\u0dca\u0dad \u0dbd\u0db6\u0dcf\u0d9c\u0dad\u0dca \u0dc0\u0dcf\u0dba\u0dd4\u0dc0\u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0d86\u0dbb\u0dca\u0dbb\u0dad\u0dcf\u0dc0\u0dba \u0dc3\u0dca\u0dad\u0dca\u200d\u0dc4 \u0d8b\u0db4\u0dbb\u0dd2\u0db8 \u0d8b\u0dc2\u0dbb\u0dab\u0dad\u0dca\u0dc0 \u0d85\u0d9c\u0dba\u0dba\u0db1\u0dca\u0dad \u0dc0\u0dba\u0dcf\u0daf\u0dcf \u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca\u0dad \u0dc0\u0dc4\u0da7 \u0daf\u0dd2\u0db1\u0dba \u0dc3\u0dca\u0dad\u0dca\u200d\u0daf\u0dc4\u0dcf \u0d9c\u0dab\u0db1\u0dba \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0daf\u0dbb\u0dca\u0dc1\u0d9a\u0dba\u0d9a\u0dca \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0dc0\u0db8\u0dba \u0dc1\u0dbb\u0dd3\u0dbb\u0dba\u0da7 \u0daf\u0dd0\u0dc0\u0db1\u0db1 \u0dad\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dd2. \u0dc0\u0db8\u0dba \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0d8b\u0db4\u0dbb\u0dd2\u0db8 \u0dc0\u0dcf\u0dba\u0dd4\u0dc0\u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0d8b\u0dc2\u0dbb\u0dab\u0dad\u0dca\u0dc0\u0dba \u0dc0\u0db1\u0dcf\u0dc0\u0dda. \u0d91\u0db8 \u0daf\u0dbb\u0dca\u0dc1\u0d9a\u0dba \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dd2\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb \u0dc1\u0dbb\u0dd3\u0dbb \u0dc0\u0dc3\u0dca\u0dad\u0dca\u200d\u0dde\u0d9b\u0dba \u0dad\u0dad\u0dca\u0dc0\u0dba\u0da7 \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dbd\u0db4\u0dd1\u0db8 \u0d89\u0dc4\u0dad \u0dc0\u0d9c\u0dd4\u0dc0\u0dda \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d87\u0dad. \u0dc0\u0db8\u0dba \u0dc0\u0dc3\u0dca\u0dad\u0dca\u200d\u0dde\u0d9b\u0dba \u0dc3\u0dca\u0dad\u0dca\u200d\u0dc4 \u0dc0\u0dda\u0dc1\u0dd3\u0dba \u0dc0\u0dc0\u0daf\u0dba \u0dc0\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dc0\u0dcf \u0d85\u0db8\u0dcf\u0dad\u0dba\u0dcf\u0d82\u0dc1\u0dc0\u0dda \u0dc3\u0dca\u0dad\u0dca\u200d\u0dc4\u0dc0\u0dba\u0ddd\u0d9c\u0dba \u0dc3\u0dca\u0dad\u0dca\u200d\u0dc4 \u0d8b\u0db4\u0dc0\u0daf\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb \u0d85\u0db1\u0dd4\u0dc0 \u0dc3\u0dca\u0dad\u0dca\u200d\u0d9a\u0dc3\u0dca\u0dad\u0dca\u200d\u0dcf \u0d87\u0dad. \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dc5 \u0dba\u0dd4\u0dd4 \u0d86\u0d9a\u0dcf\u0dbb\u0dba",
