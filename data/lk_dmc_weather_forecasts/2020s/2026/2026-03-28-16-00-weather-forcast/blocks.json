  {
    "page_number": 0,
    "bbox": [
      58.56,
      577.63,
      538.34,
      606.43
    ],
    "text": "Misty conditions can be expected at some places in Central, Sabaragamuwa and Uva provinces and in Galle and Matara districts during the early hours of the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      12.0
