  },
  {
    "page_number": 0,
    "bbox": [
      67.58,
      513.79,
      524.47,
      549.07
    ],
    "text": "Atmospheric conditions will be favorable for afternoon thundershowers in most parts of the island over the next few days from today (02 April).",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      0.9599999785423279,
      2.0399999618530273,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      67.58,
      553.0,
      524.82,
      593.95
    ],
    "text": "Showers or thundershowers will occur at several places in Western, Central, Sabaragamuwa, Southern, Uva, North-western and North-central provinces after 2.00 p.m.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      67.58,
      598.0,
      524.82,
      638.95
    ],
    "text": "Fairly heavy falls above 50 mm are likely at some places in Western, Central and Sabaragamuwa provinces and in Kurunegala district.",
    "fonts": [
      "Calibri",
      "Calibri,Bold"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      67.58,
      642.88,
      524.9,
      683.86
    ],
    "text": "Showers may occur at Southern province and in Ampara, Batticaloa and Monaragala districts in the morning too.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 0,
    "bbox": [
      67.58,
      687.79,
      524.88,
      728.74
    ],
    "text": "Misty conditions can be expected at some places in Central, Sabaragamuwa and Uva provinces during the early hours of the morning.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
