  {
    "page_number": 0,
    "bbox": [
      58.58,
      599.75,
      538.5,
      637.03
    ],
    "text": "Misty conditions can be expected at some places in Central, Sabaragamuwa, North-central and Uva provinces.",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      5.039999961853027,
      12.0
    ]
