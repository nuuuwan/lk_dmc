    "bbox": [
      58.56,
      479.11,
      465.17,
      517.99
    ],
    "text": "Issued at 04.00 p.m. on 13 April 2026. Showers or thundershowers will occur at most places of the island after 1.00 pm.",
    "fonts": [
      "Calibri,Bold",
      "Iskoola Pota,Bold"
    ],
    "sizes": [
      8.039999961853027,
