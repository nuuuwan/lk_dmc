    "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0d8a\u0dc3\u0dcf\u0db1 \u0d9c\u0daf\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dcf \u0d87\u0dad\u0dd2 \u0d85\u0da9\u0dd4 \u0db4\u0dd3\u0da9\u0db1 \u0d9a\u0dbd\u0dcf\u0dd9\u0dba \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dd9\u0dc0\u0dad\u0dd3. \u0d91\u0db8 \u0dd9\u0dda\u0db0\u0dad\u0dd2\u0dba, \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0dd9\u0dd0\u0dba 36 \u0dad\u0dd4\u0dbd \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dcf\u0d9c\u0dc0\u0db1\u0dca \u0d89\u0dc0\u0dad\u0da7 \u0dd9\u0db8\u0db1\u0dca \u0d9a\u0dbb\u0db1\u0dd4 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d85\u0d9c\u0dda\u0d9a\u0dca\u0dcf \u0d9c\u0d9a\u0d9c\u0dda. \u0d9c\u0db8\u0db8 \u0dd9\u0dda\u0db0\u0dad\u0dd2\u0d9c\u0dda \u0db6\u0dbd\u0dd9\u0dd1\u0db8 \u0d9c\u0dc4\u0dda\u0dad\u0dd4\u0d9c\u0dc0\u0db1\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0daf\u0dd2\u0db1\u0dc0\u0dbd\u0daf\u0dd3 \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1 \u0dc0\u0da7\u0dcf\u0dc0\u0db1 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0d9c\u0dda\u0dc1\u0dc0\u0dbd \u0dc3\u0dd4\u0dc5\u0d9c\u0dda \u0d9c\u0dda\u0dd9\u0dba \u0dc3\u0dc4 \u0dc0\u0dd0\u0dc3\u0dd2 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a. \u0db6\u0db8\u0dca \u0dc3\u0db8\u0dca \u0db1\u0dca\u0db0\u0db6\u0dba\u0db1\u0dca \u0d9a\u0ddc\u0dbd\u0d9c\u0dd4\u0dab \u0dc0\u0dd2\u0dd9\u0dba\u0ddc \u0db6\u0dd9\u0db4\u0ddc\u0dbb\u0dca\u0dad\u0db6\u0db8\u0dca\u0db1\u0dca\u0dd4\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd \u0db1 \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0d85\u0db1\u0ddc\u0dc0\u0dd0\u0d9a\u0dd2 \u0dc3 \u0db1\u0dd2\u0db6\u0dda\u0dd9\u0db1 \u0db4\u0dd2\u0dc5\u0dd2 \u0db3\u0dc0 \u0d85\u0dc0\u0db0\u0ddc\u0db1\u0db6\u0dba\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0\u0db1 \u0db6\u0dbd\u0dc3 \u0db0\u0dd3\u0dc0\u0dbb \u0dc3 \u0db1\u0ddc\u0dc0\u0dd4\u0d9a \u0db4\u0dca\u